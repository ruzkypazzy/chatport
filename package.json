{
  "name": "chatport",
  "version": "0.1.0",
  "description": "MCP server for exporting, compressing, branching, merging, verifying, and resuming AI coding sessions between OpenAI and MiniMax M3",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "smoke": "npm run build && node scripts/smoke-sse.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "better-sqlite3": "12.10.0",
    "cors": "2.8.6",
    "diff": "9.0.0",
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "openai": "6.42.0",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "uuid": "14.0.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/node": "25.9.3",
    "@types/supertest": "7.2.0",
    "supertest": "7.2.2",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  }
}
