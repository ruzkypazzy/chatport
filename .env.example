# Server
# Port the Express server listens on. Default: 3000
PORT=3000

# pino log level. Default: info
LOG_LEVEL=info

# Default per-tool timeout in milliseconds. Default: 30000
TOOL_TIMEOUT_MS=30000

# SQLite
# Filesystem path to the SQLite database file. Default: ./chatport.db
DATABASE_PATH=./chatport.db

# OpenAI
# API key for OpenAI. Required for export_session, continue_in (target_llm=openai).
OPENAI_API_KEY=

# Base URL for the OpenAI-compatible API. Default: https://api.openai.com/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# Default model to use for OpenAI calls. Default: gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini

# MiniMax M3 (OpenAI-compatible)
# API key for MiniMax M3. Required for summarize_progress, extract_*,
# continue_in (target_llm=MiniMax), branch_session, merge_sessions (summarize).
MINIMAX_API_KEY=

# Base URL for the MiniMax-compatible API. Default: https://api.minimax.io/v1
MINIMAX_BASE_URL=https://api.minimax.io/v1

# Default model to use for MiniMax calls. Default: MiniMax-M3
MINIMAX_MODEL=MiniMax-M3
